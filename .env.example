# Private key generated by Google Cloud Console
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n ... =\n-----END PRIVATE KEY-----\n"

# Selected API secret pin for the app (you can change it to whatever you want, but keep it secret!)
API_SECRET_PIN="YourSecretPin123!"

# Names of the sheets in the Google Spreadsheet you create
EXP_SHEET_NAME="Expenses"
MARKET_SHEET_NAME="Markets"